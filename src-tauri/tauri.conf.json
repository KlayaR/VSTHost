{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VSTHost",
  "version": "1.3.0",
  "identifier": "com.vsthost.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VSTHost",
        "width": 1100,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "backgroundColor": "#0f1117",
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/icon.ico",
      "icons/128x128.png",
      "icons/32x32.png"
    ],
    "resources": {
      "../engine/build/VSTHostEngine_artefacts/Release/VSTHostEngine.exe": "engine/VSTHostEngine.exe"
    }
  }
}
